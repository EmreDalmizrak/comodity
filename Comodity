@dataclass
class CommodityConfig:
    """
    Per-commodity configuration.
    Fields are populated from live data; fallbacks are used if fetch fails.
    """
    name:        str
    symbol:      str            # internal key: OIL | GAS | GOLD
    unit:        str            # currency symbol for display
    decimals:    int            # display decimal places
    spot:        float          # current / most recent price
    drift:       float          # annualised drift μ (from live data)
    sigma:       float          # annualised volatility σ (from live data)
    implied_vol: float          # implied vol from OVX / proxy

    # Fallback values used when live data is unavailable
    _fallback_spot:  float = 0.0
    _fallback_sigma: float = 0.0
    _fallback_drift: float = 0.0


# Hard-coded fallbacks in case Yahoo Finance is unreachable
_FALLBACKS: Dict[str, dict] = {
    "OIL":  dict(name="Crude Oil (WTI)", unit="$", decimals=2,
                 spot=85.0,   sigma=0.28, drift=0.05),
    "GAS":  dict(name="Natural Gas",     unit="$", decimals=3,
                 spot=2.80,   sigma=0.55, drift=0.02),
    "GOLD": dict(name="Gold",            unit="$", decimals=0,
                 spot=2340.0, sigma=0.15, drift=0.06),
}


def build_commodity_configs(md: MarketData) -> Dict[str, CommodityConfig]:
    """
    Build CommodityConfig objects calibrated from live data.
    Falls back to hard-coded values if data is missing.
    """
    configs: Dict[str, CommodityConfig] = {}
    for sym, fb in _FALLBACKS.items():
        spot  = md.spot.get(sym,       fb["spot"])
        sigma = md.ann_vol.get(sym,    fb["sigma"])
        drift = md.ann_drift.get(sym,  fb["drift"])

        # Use OVX level as implied vol for oil (OVX is in % not decimal)
        if sym == "OIL":
            implied = md.ovx_level / 100.0 if md.ovx_level > 0 else sigma * 1.15
        elif sym == "GAS":
            implied = sigma * 1.20   # gas options carry a vol premium
        else:  # GOLD
            implied = sigma * 1.10

        configs[sym] = CommodityConfig(
            name=fb["name"],
            symbol=sym,
            unit=fb["unit"],
            decimals=fb["decimals"],
            spot=spot,
            drift=drift,
            sigma=sigma,
            implied_vol=implied,
            _fallback_spot=fb["spot"],
            _fallback_sigma=fb["sigma"],
            _fallback_drift=fb["drift"],
        )

    return configs


