@dataclass
class MarketData:
    """All downloaded and derived market data in one place."""
    # raw OHLCV DataFrames keyed by our internal symbol
    ohlcv:   Dict[str, pd.DataFrame] = field(default_factory=dict)
    # adjusted close price series
    close:   Dict[str, pd.Series]    = field(default_factory=dict)
    # daily log-return series
    returns: Dict[str, pd.Series]    = field(default_factory=dict)
    # FRED series
    fred:    Dict[str, pd.Series]    = field(default_factory=dict)
    # scalar summaries
    spot:    Dict[str, float]        = field(default_factory=dict)
    ann_vol: Dict[str, float]        = field(default_factory=dict)   # realised annualised σ
    ann_drift: Dict[str, float]      = field(default_factory=dict)   # annualised μ
    # implied vols from index levels (OVX, VIX are already % per year)
    ovx_level: float = 30.0   # OVX closing level (%)
    vix_level: float = 20.0   # VIX closing level (%)


def _start_date(years: int) -> str:
    return (datetime.today() - timedelta(days=years * 365)).strftime("%Y-%m-%d")


def fetch_yahoo_ticker(symbol: str, internal_key: str, years: int = HISTORY_YEARS) -> pd.DataFrame:
    """
    Download OHLCV data from Yahoo Finance for a single ticker.
    Returns empty DataFrame on failure.
    """
    start = _start_date(years)
    try:
        df = yf.download(
            symbol,
            start=start,
            progress=False,
            auto_adjust=True,
            threads=False,
        )
        if df.empty:
            raise ValueError("Empty response")
        # yfinance >= 0.2 returns MultiIndex columns when downloading single ticker
        if isinstance(df.columns, pd.MultiIndex):
            df.columns = df.columns.get_level_values(0)
        df.index = pd.to_datetime(df.index)
        df.index.name = "Date"
        return df
    except Exception as exc:
        print(f"    ✗  Yahoo [{symbol}] — {exc}")
        return pd.DataFrame()


def fetch_fred_series(series_id: str, years: int = HISTORY_YEARS * 2) -> pd.Series:
    """
    Download a public FRED series via pandas-datareader.
    Returns empty Series on failure.
    """
    if not FRED_AVAILABLE:
        return pd.Series(dtype=float, name=series_id)
    start = _start_date(years)
    try:
        df = web.get_data_fred(series_id, start=start)
        s = df.iloc[:, 0].dropna()
        s.index = pd.to_datetime(s.index)
        s.name = series_id
        return s
    except Exception as exc:
        print(f"    ✗  FRED [{series_id}] — {exc}")
        return pd.Series(dtype=float, name=series_id)


def compute_return_stats(close: pd.Series) -> Tuple[float, float]:
    """Return (annualised_drift, annualised_vol) from a close price series."""
    lr = np.log(close / close.shift(1)).dropna()
    ann_vol   = float(lr.std()  * np.sqrt(TRADING_DAYS))
    ann_drift = float(lr.mean() * TRADING_DAYS)
    return ann_drift, ann_vol


def load_all_data() -> MarketData:
    """
    Master data loader.
    Downloads Yahoo Finance OHLCV for all tickers, then FRED macro series.
    Computes log-returns and annualised statistics for each.
    """
    md = MarketData()
    sep = "═" * 64

    print(f"\n{sep}")
    print("  📡  Downloading live market data")
    print(f"{sep}")

    # ── 2a. Yahoo Finance ─────────────────────────────────────────────────────
    print("\n  Yahoo Finance")
    print("  " + "─" * 60)
    for key, ticker in YAHOO_TICKERS.items():
        print(f"  {ticker:<14} ({key:<5})", end="  ")
        df = fetch_yahoo_ticker(ticker, key)
        if df.empty:
            print("skipped")
            continue

        md.ohlcv[key] = df
        col = "Close" if "Close" in df.columns else df.columns[0]
        close = df[col].dropna()
        md.close[key]   = close
        md.spot[key]    = float(close.iloc[-1])
        lr = np.log(close / close.shift(1)).dropna()
        md.returns[key] = lr
        drift, vol = compute_return_stats(close)
        md.ann_drift[key] = drift
        md.ann_vol[key]   = vol

        # special: OVX and VIX are index levels (already %-implied vol)
        if key == "OVX":
            md.ovx_level = float(close.iloc[-1])
        if key == "VIX":
            md.vix_level = float(close.iloc[-1])

        print(
            f"✓  latest={md.spot[key]:>10.3f}  "
            f"ann_vol={vol*100:5.1f}%  "
            f"ann_drift={drift*100:+6.1f}%  "
            f"obs={len(close)}"
        )

    # ── 2b. FRED ─────────────────────────────────────────────────────────────
    if FRED_AVAILABLE:
        print("\n  FRED (St. Louis Fed)")
        print("  " + "─" * 60)
        for name, sid in FRED_TICKERS.items():
            print(f"  {sid:<28} ({name})", end="  ")
            s = fetch_fred_series(sid)
            if s.empty:
                print("skipped")
                continue
            md.fred[name] = s
            print(
                f"✓  obs={len(s):<5}  "
                f"from {s.index[0].date()}  "
                f"to {s.index[-1].date()}  "
                f"latest={s.iloc[-1]:.3f}"
            )
    else:
        print("\n  FRED skipped (pandas-datareader not installed)")

    print(f"\n{sep}\n")
    return md


