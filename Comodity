# Colour palette
BLUE   = "#185FA5"
RED    = "#E24B4A"
GREEN  = "#1D9E75"
AMBER  = "#BA7517"
PURPLE = "#534AB7"
GRAY   = "#888888"


def _pct_bands(paths: np.ndarray):
    """Return (p5, p25, median, p75, p95) day-by-day."""
    return (
        np.percentile(paths,  5, axis=0),
        np.percentile(paths, 25, axis=0),
        np.median(paths,        axis=0),
        np.percentile(paths, 75, axis=0),
        np.percentile(paths, 95, axis=0),
    )


def _style_ax(ax):
    ax.spines[["top", "right"]].set_visible(False)
    ax.grid(alpha=0.15, linewidth=0.5, linestyle="--")
    ax.tick_params(labelsize=8)


# ── Chart 1: Full simulation dashboard ────────────────────────────────────────

def plot_simulation_dashboard(
    results:        Dict[str, np.ndarray],
    com_configs:    Dict[str, CommodityConfig],
    historical:     Dict[str, pd.Series],
    scenario:       GeoScenario,
    save_path:      Optional[str] = None,
) -> None:
    """
    3-row × 3-column figure:
      Row 0: 2-year historical price chart
      Row 1: Monte Carlo fan chart (simulated paths)
      Row 2: Final-price return distribution with stats overlay
    """
    symbols = list(results.keys())
    ncols   = len(symbols)

    fig = plt.figure(figsize=(9 * ncols, 13), facecolor="white")
    fig.suptitle(
        f"Commodity Monte Carlo Simulation  —  Iran-Israel Conflict\n"
        f"Scenario: {scenario.label}   |   "
        f"{results[symbols[0]].shape[0]:,} paths  ×  "
        f"{results[symbols[0]].shape[1]-1} trading days",
        fontsize=14, fontweight="bold", y=1.01,
    )

    gs = gridspec.GridSpec(
        3, ncols,
        figure=fig,
        hspace=0.52,
        wspace=0.32,
        height_ratios=[1, 2.2, 1.4],
    )

    for col, sym in enumerate(symbols):
        cc    = com_configs[sym]
        paths = results[sym]
        T     = paths.shape[1] - 1
        days  = np.arange(T + 1)
        st    = compute_statistics(paths, cc.spot)
        p5, p25, med, p75, p95 = _pct_bands(paths)

        # ── Row 0: historical price ──────────────────────────────────────────
        ax0 = fig.add_subplot(gs[0, col])
        hist_s = historical.get(sym)
        if hist_s is not None and not hist_s.empty:
            h = hist_s.iloc[-504:]   # last ~2 trading years
            ax0.plot(h.index, h.values, lw=1.3, color=BLUE, alpha=0.9)
            ax0.fill_between(h.index, h.values, h.values.min(),
                             alpha=0.08, color=BLUE)
            # mark last point
            ax0.scatter([h.index[-1]], [h.iloc[-1]], color=BLUE, s=30, zorder=5)
            ax0.set_xlabel("", fontsize=8)
            ax0.xaxis.set_major_formatter(
                matplotlib.dates.DateFormatter("%b '%y")
            )
            plt.setp(ax0.xaxis.get_majorticklabels(), rotation=30, ha="right")
        else:
            ax0.text(0.5, 0.5, "No historical data",
                     ha="center", va="center", transform=ax0.transAxes,
                     fontsize=10, color=GRAY)
        ax0.set_title(f"{cc.name}", fontsize=12, fontweight="bold", pad=7)
        ax0.set_ylabel(f"Price ({cc.unit})", fontsize=9)
        _style_ax(ax0)

        # ── Row 1: Monte Carlo fan chart ─────────────────────────────────────
        ax1 = fig.add_subplot(gs[1, col])
        ax1.fill_between(days, p5,  p95, alpha=0.11, color=BLUE, label="90% CI")
        ax1.fill_between(days, p25, p75, alpha=0.26, color=BLUE, label="50% CI")
        ax1.plot(days, med, color=BLUE,  lw=2.5, label="Median")
        ax1.plot(days, p95, color=RED,   lw=1.2, ls="--", label="95th pct")
        ax1.plot(days, p5,  color=GREEN, lw=1.2, ls="--", label="5th pct")
        ax1.axhline(cc.spot, color=GRAY, lw=1.0, ls=":", alpha=0.7, label="Spot today")

        ax1.set_title(
            f"Simulation  ·  μ={st['exp_ret_pct']:+.1f}%  "
            f"σ={st['ann_vol_sim']*100:.1f}%  "
            f"Sharpe={st['sharpe']:.2f}",
            fontsize=9, pad=5,
        )
        ax1.set_xlabel("Trading days", fontsize=9)
        ax1.set_ylabel(f"Price ({cc.unit})", fontsize=9)
        _style_ax(ax1)

        if col == 0:
            legend_els = [
                Line2D([0],[0], color=BLUE,  lw=2.5,  label="Median"),
                Line2D([0],[0], color=RED,   lw=1.2,  ls="--", label="95th pct"),
                Line2D([0],[0], color=GREEN, lw=1.2,  ls="--", label="5th pct"),
                Patch(facecolor=BLUE, alpha=0.26, label="50% CI"),
                Patch(facecolor=BLUE, alpha=0.11, label="90% CI"),
                Line2D([0],[0], color=GRAY, lw=1.0, ls=":", label="Spot today"),
            ]
            ax1.legend(handles=legend_els, fontsize=8,
                       loc="upper left", framealpha=0.92)

        # ── Row 2: return distribution histogram ─────────────────────────────
        ax2 = fig.add_subplot(gs[2, col])
        final   = paths[:, -1]
        returns = (final / cc.spot - 1) * 100
        n_bins  = 55
        counts, edges = np.histogram(returns, bins=n_bins)
        centers = (edges[:-1] + edges[1:]) / 2
        bw      = edges[1] - edges[0]

        bar_colors = np.where(
            centers < -10, RED,
            np.where(centers > 10, GREEN, BLUE)
        )
        ax2.bar(centers, counts, width=bw * 0.88,
                color=bar_colors, alpha=0.78, edgecolor="none")

        ax2.axvline(0,                  color=GRAY, lw=1.0, ls=":",  alpha=0.8)
        ax2.axvline(np.median(returns), color=BLUE, lw=1.5, ls="--", alpha=0.9,
                    label=f"Median {np.median(returns):+.1f}%")

        # overlay normal PDF if scipy available
        if SCIPY_AVAILABLE and len(returns) > 30:
            xr = np.linspace(returns.min(), returns.max(), 300)
            pdf = scipy_stats.norm.pdf(xr, returns.mean(), returns.std())
            scale = counts.max() / pdf.max() * 0.88
            ax2.plot(xr, pdf * scale, lw=1.5, color="#333", alpha=0.45,
                     ls="-", label="Normal fit")

        ax2.set_title(
            f"Return distribution  ·  VaR95={cc.unit}{st['var_loss']:.{cc.decimals}f}",
            fontsize=9, pad=5,
        )
        ax2.set_xlabel(f"Return at day {T} (%)", fontsize=9)
        ax2.set_ylabel("Frequency", fontsize=9)
        _style_ax(ax2)
        ax2.grid(alpha=0.15, axis="y")
        ax2.legend(fontsize=8, framealpha=0.9)

        # stats annotation box
        ann_text = (
            f"P(>+5%):   {st['prob_up5']:.1f}%\n"
            f"P(>+10%): {st['prob_up10']:.1f}%\n"
            f"P(<-5%):   {st['prob_down5']:.1f}%\n"
            f"P(<-10%): {st['prob_down10']:.1f}%\n"
            f"Avg MaxDD: {st['avg_max_dd']*100:.1f}%"
        )
        ax2.text(0.98, 0.97, ann_text,
                 transform=ax2.transAxes, fontsize=7.5,
                 va="top", ha="right",
                 bbox=dict(boxstyle="round,pad=0.4",
                           fc="white", ec="#cccccc", alpha=0.92))

    plt.tight_layout()
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight")
        print(f"  Chart 1 saved  →  {save_path}")
    plt.show()


# ── Chart 2: Scenario comparison ──────────────────────────────────────────────

def plot_scenario_comparison(
    com_configs:  Dict[str, CommodityConfig],
    n_paths:      int = 500,
    horizon_days: int = 90,
    save_path:    Optional[str] = None,
) -> None:
    """
    One subplot per commodity.
    Each subplot shows median price paths for all five scenarios.
    """
    sc_colors = {
        "Base case":         BLUE,
        "Mild escalation":   AMBER,
        "Severe escalation": "#D85A30",
        "Strait closure":    RED,
        "De-escalation":     GREEN,
    }
    symbols = list(com_configs.keys())
    fig, axes = plt.subplots(
        1, len(symbols),
        figsize=(9 * len(symbols), 5.5),
        facecolor="white",
    )
    if len(symbols) == 1:
        axes = [axes]

    fig.suptitle(
        "Scenario Comparison — Median Price Paths  (Iran-Israel Conflict)",
        fontsize=14, fontweight="bold",
    )

    for ax, sym in zip(axes, symbols):
        cc = com_configs[sym]
        for sc_name, geo in SCENARIOS.items():
            paths = run_monte_carlo(
                cc, geo,
                n_paths=n_paths,
                horizon_days=horizon_days,
                seed=99,
            )
            med  = np.median(paths, axis=0)
            p25  = np.percentile(paths, 25, axis=0)
            p75  = np.percentile(paths, 75, axis=0)
            days = np.arange(len(med))
            clr  = sc_colors[sc_name]
            ax.plot(days, med, lw=2.2, color=clr, label=sc_name)
            ax.fill_between(days, p25, p75, alpha=0.08, color=clr)

        ax.axhline(cc.spot, color=GRAY, lw=1.0, ls=":", alpha=0.8, label="Spot today")
        ax.set_title(cc.name, fontsize=12, fontweight="bold")
        ax.set_xlabel("Trading days")
        ax.set_ylabel(f"Price ({cc.unit})")
        ax.legend(fontsize=9, framealpha=0.92)
        _style_ax(ax)

    plt.tight_layout()
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight")
        print(f"  Chart 2 saved  →  {save_path}")
    plt.show()


# ── Chart 3: Return correlation heatmap ───────────────────────────────────────

def plot_correlation_heatmap(
    md:        MarketData,
    save_path: Optional[str] = None,
) -> None:
    """
    Pairwise Pearson correlation of daily log-returns.
    Includes commodities, VIX, and USD index for context.
    """
    key_map = {
        "OIL":  "WTI Oil",
        "GAS":  "Nat Gas",
        "GOLD": "Gold",
        "VIX":  "VIX",
        "DXY":  "USD Index",
        "XLE":  "Energy ETF",
        "GLD":  "Gold ETF",
    }
    available = [k for k in key_map if k in md.returns]
    if len(available) < 2:
        print("  ⚠  Not enough return series for correlation heatmap — skipped.")
        return

    df = pd.concat(
        [md.returns[k].rename(key_map[k]) for k in available],
        axis=1,
    ).dropna()
    corr = df.corr()

    fig, ax = plt.subplots(figsize=(7, 6), facecolor="white")
    n  = len(corr)
    im = ax.imshow(corr.values, cmap="RdBu_r", vmin=-1, vmax=1, aspect="auto")
    cbar = plt.colorbar(im, ax=ax, shrink=0.80, pad=0.02)
    cbar.ax.tick_params(labelsize=9)
    cbar.set_label("Pearson r", fontsize=9)

    ax.set_xticks(range(n))
    ax.set_yticks(range(n))
    ax.set_xticklabels(corr.columns, rotation=35, ha="right", fontsize=10)
    ax.set_yticklabels(corr.index,   fontsize=10)
    ax.set_title(
        "Daily Return Correlation Matrix  (live data)",
        fontsize=12, fontweight="bold", pad=12,
    )

    for i in range(n):
        for j in range(n):
            val = corr.values[i, j]
            ax.text(
                j, i, f"{val:.2f}",
                ha="center", va="center", fontsize=9,
                color="white" if abs(val) > 0.45 else "black",
            )

    ax.spines[:].set_visible(False)
    plt.tight_layout()
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight")
        print(f"  Chart 3 saved  →  {save_path}")
    plt.show()


# ── Chart 4: Historical volatility vs. implied vol ────────────────────────────

def plot_volatility_regimes(
    md:         MarketData,
    save_path:  Optional[str] = None,
) -> None:
    """
    Rolling 30-day realised vol for oil, gas, gold  +  OVX / VIX levels.
    Useful for understanding whether current vol is elevated or compressed.
    """
    fig, axes = plt.subplots(3, 1, figsize=(12, 9), facecolor="white", sharex=False)
    fig.suptitle(
        "Historical Volatility Regimes  (30-day rolling annualised σ)",
        fontsize=13, fontweight="bold",
    )

    pairs = [
        ("OIL",  "WTI Crude Oil",  BLUE,   "OVX",  "OVX implied"),
        ("GAS",  "Natural Gas",    AMBER,  None,   None),
        ("GOLD", "Gold",           GREEN,  "VIX",  "VIX (proxy)"),
    ]
    for ax, (sym, label, clr, vol_key, vol_label) in zip(axes, pairs):
        if sym not in md.returns or md.returns[sym].empty:
            ax.text(0.5, 0.5, f"No data for {sym}",
                    ha="center", va="center", transform=ax.transAxes,
                    fontsize=11, color=GRAY)
            ax.set_title(label, fontsize=11)
            continue

        rv = md.returns[sym].rolling(30).std() * np.sqrt(TRADING_DAYS) * 100
        ax.plot(rv.index, rv.values, lw=1.5, color=clr, label="Realised vol (30d)")
        ax.fill_between(rv.index, rv.values, alpha=0.10, color=clr)

        if vol_key and vol_key in md.close and not md.close[vol_key].empty:
            iv = md.close[vol_key].reindex(rv.index, method="ffill")
            ax.plot(iv.index, iv.values, lw=1.3, color=RED,
                    ls="--", alpha=0.75, label=vol_label)

        ax.set_title(label, fontsize=11, fontweight="bold")
        ax.set_ylabel("Annualised vol (%)", fontsize=9)
        ax.legend(fontsize=8, framealpha=0.9)
        _style_ax(ax)

    plt.tight_layout()
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight")
        print(f"  Chart 4 saved  →  {save_path}")
    plt.show()


