#  SECTION 5 — MONTE CARLO ENGINE
# ══════════════════════════════════════════════════════════════════════════════

def run_monte_carlo(
    cc:           CommodityConfig,
    geo:          GeoScenario,
    n_paths:      int  = 1000,
    horizon_days: int  = 90,
    seed:         Optional[int] = 42,
) -> np.ndarray:
    """
    Simulate commodity price paths using:

        dS = S·[μ dt + σ√dt Z]          ← GBM
             − κ(S − S₀) dt              ← Ornstein-Uhlenbeck mean reversion
             + S·J·dN_esc               ← Poisson escalation jumps
             + S·K·1[strait closes]     ← one-time Strait of Hormuz event

    Parameters
    ----------
    cc            : CommodityConfig  (spot, drift, sigma from live data)
    geo           : GeoScenario      (geopolitical shock parameters)
    n_paths       : number of Monte Carlo paths
    horizon_days  : forecast horizon in trading days
    seed          : random seed for reproducibility (None = random)

    Returns
    -------
    paths : np.ndarray  shape (n_paths, horizon_days + 1)
            paths[:, 0]  = S0 (spot price)
            paths[:, t]  = simulated price at day t
    """
    rng    = np.random.default_rng(seed)
    S0     = cc.spot
    mu     = cc.drift
    sigma  = cc.sigma
    kappa  = geo.mean_reversion
    dt     = 1.0 / TRADING_DAYS            # one trading day in years

    strait_impact = getattr(geo, _STRAIT_ATTR[cc.symbol])

    # shape: (n_paths, horizon_days + 1)
    paths = np.empty((n_paths, horizon_days + 1), dtype=np.float64)
    paths[:, 0] = S0

    # current price vector  (updated in-place each step)
    S = np.full(n_paths, S0, dtype=np.float64)

    # track which paths have experienced a strait closure (one-time event)
    strait_closed = np.zeros(n_paths, dtype=bool)

    for t in range(horizon_days):

        # ── GBM increment ───────────────────────────────────────────────────
        Z   = rng.standard_normal(n_paths)
        gbm = (mu - 0.5 * sigma ** 2) * dt + sigma * np.sqrt(dt) * Z

        # ── Mean reversion (pull toward long-run equilibrium S₀) ────────────
        mr = -kappa * (S - S0) * dt

        # ── Escalation shocks (Poisson, per-day probability) ────────────────
        esc_mask  = rng.random(n_paths) < geo.escalation_prob_daily
        # shock magnitude drawn from a half-normal to ensure positivity
        raw_shock = np.abs(rng.normal(
            geo.shock_magnitude_mean,
            geo.shock_magnitude_std,
            n_paths,
        ))
        escalation_jump = raw_shock * esc_mask   # zero if no shock

        # ── Strait of Hormuz closure (one-time structural shock) ────────────
        new_closure  = (~strait_closed) & (rng.random(n_paths) < geo.strait_prob_daily)
        strait_closed |= new_closure
        # extra random spread on strait impact
        strait_jump = (
            strait_impact + rng.uniform(0, 0.05, n_paths)
        ) * new_closure

        # ── Combine all components ───────────────────────────────────────────
        S = S * np.exp(gbm)          # apply GBM multiplicatively
        S = S + mr                   # mean reversion additive
        S = S * (1.0 + escalation_jump)
        S = S * (1.0 + strait_jump)
        S = np.maximum(S, 0.01)      # price floor

        paths[:, t + 1] = S

    return paths


