#  SECTION 6 — STATISTICS
# ══════════════════════════════════════════════════════════════════════════════

def compute_statistics(paths: np.ndarray, spot: float) -> dict:
    """
    Compute a comprehensive set of statistics from simulation output.

    Parameters
    ----------
    paths : np.ndarray  shape (n_paths, horizon + 1)
    spot  : float       current spot price (paths[:, 0])

    Returns
    -------
    stats : dict
    """
    final    = paths[:, -1]
    T        = paths.shape[1] - 1
    n_paths  = paths.shape[0]

    # percentiles
    pcts = np.percentile(final, [1, 5, 10, 25, 50, 75, 90, 95, 99])

    # VaR and CVaR at 95% confidence
    var_95  = pcts[1]   # 5th percentile of final price
    tail    = final[final <= var_95]
    cvar_95 = float(tail.mean()) if len(tail) > 0 else float(var_95)

    # returns (log)
    log_ret  = np.log(paths[:, 1:] / paths[:, :-1])     # shape (n_paths, T)
    path_ret = np.log(final / spot)                       # total log-return each path
    mu_r     = float(log_ret.mean() * TRADING_DAYS)       # annualised mean
    sig_r    = float(log_ret.std()  * np.sqrt(TRADING_DAYS))  # annualised vol
    sharpe   = mu_r / sig_r if sig_r > 0 else 0.0

    # max drawdown (averaged across paths)
    running_max  = np.maximum.accumulate(paths, axis=1)
    drawdowns    = (paths - running_max) / running_max    # negative values
    max_dd_paths = drawdowns.min(axis=1)
    avg_max_dd   = float(max_dd_paths.mean())

    return {
        "n_paths":     n_paths,
        "horizon":     T,
        "spot":        float(spot),
        "mean":        float(final.mean()),
        "median":      float(np.median(final)),
        "std":         float(final.std()),
        "skewness":    float(scipy_stats.skew(final)) if SCIPY_AVAILABLE else float("nan"),
        "kurtosis":    float(scipy_stats.kurtosis(final)) if SCIPY_AVAILABLE else float("nan"),
        "p1":  float(pcts[0]),  "p5":  float(pcts[1]),  "p10": float(pcts[2]),
        "p25": float(pcts[3]),  "p50": float(pcts[4]),  "p75": float(pcts[5]),
        "p90": float(pcts[6]),  "p95": float(pcts[7]),  "p99": float(pcts[8]),
        "var_95":      float(var_95),
        "cvar_95":     float(cvar_95),
        "var_loss":    float(abs(spot - var_95)),
        "sharpe":      float(sharpe),
        "ann_vol_sim": float(sig_r),
        "avg_max_dd":  float(avg_max_dd),
        "exp_ret_pct": float((final.mean() / spot - 1) * 100),
        "prob_up":     float((final > spot).mean() * 100),
        "prob_up5":    float((final > spot * 1.05).mean() * 100),
        "prob_up10":   float((final > spot * 1.10).mean() * 100),
        "prob_up20":   float((final > spot * 1.20).mean() * 100),
        "prob_down5":  float((final < spot * 0.95).mean() * 100),
        "prob_down10": float((final < spot * 0.90).mean() * 100),
        "prob_down20": float((final < spot * 0.80).mean() * 100),
    }


def print_statistics(st: dict, name: str, unit: str = "$", decimals: int = 2) -> None:
    """Pretty-print statistics to the terminal."""
    w   = 62
    fmt = lambda v: f"{unit}{v:>12,.{decimals}f}"
    pct = lambda v: f"  {v:>10.1f}%"
    flt = lambda v: f"  {v:>10.3f}"

    print(f"\n{'═'*w}")
    print(f"  {name}")
    print(f"  {st['n_paths']:,} paths  ×  {st['horizon']} trading days")
    print(f"{'─'*w}")
    rows = [
        ("Spot price today",              fmt(st['spot'])),
        ("", ""),
